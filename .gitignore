# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build artifacts
dist/
build/
*.egg-info/

# LanceDB data (rebuild with: python knowledge-base/build_kb.py)
knowledge-base/lancedb/

# HTML companion _files folders (JS/CSS/images saved by browser — not needed)
knowledge-base/*_files/

# Raw source files (large, copyrighted — not needed in git)
# The processed chunks.json IS committed (it's the deliverable)
knowledge-base/*.pdf
knowledge-base/*.html
knowledge-base/chunks_html.json
knowledge-base/chunks_pdf.json

# Claude internal files
.claude/

# Environment
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
